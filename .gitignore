# Claude Code — local / user-specific
.claude/settings.local.json
.claude/*.local.json
.claude/.credentials.json

# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/
.python-version

# Node / TypeScript
node_modules/
dist/
*.tsbuildinfo

# MkDocs build output
/site/

# Generated by docs catalog hook (mkdocs-gen-files) — never commit catalog markdown
/docs/de/skills/*/
/docs/de/agents/*/
/docs/de/skills/index.md
/docs/de/agents/index.md
/docs/de/skills/SUMMARY.md
/docs/de/agents/SUMMARY.md
/docs/de/tags.md

# Task runner cache
.task/

# Audits — local-only, findings convert to issues/PRs
.audits/

# Vale — style packages fetched by `vale sync` (keep repo-local vocab)
.github/styles/*
!.github/styles/config/
.github/styles/config/vocabularies/*

# Environment
.env
.env.*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
