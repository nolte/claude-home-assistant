# Claude Code — local / user-specific
.claude/settings.local.json
.claude/*.local.json
.claude/.credentials.json

# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/
.python-version

# Node / TypeScript
node_modules/
dist/
*.tsbuildinfo

# MkDocs build output
/site/

# Generated by docs catalog hook (scripts/docs/gen_catalog.py) into the
# canonical-language docs tree (docs/en/) — never commit catalog markdown
/docs/en/skills/*/
/docs/en/agents/*/
/docs/en/skills/index.md
/docs/en/agents/index.md
/docs/en/skills/SUMMARY.md
/docs/en/agents/SUMMARY.md
/docs/en/tags.md

# Task runner cache
.task/

# Audits — local-only, findings convert to issues/PRs
.audits/

# Vale — style packages fetched by `vale sync` (keep repo-local vocab)
.github/styles/*
!.github/styles/config/
.github/styles/config/vocabularies/*

# Environment
.env
.env.*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

